# ── SERVER ──────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── ADMIN DASHBOARD ─────────────────────────────────
# Change these before deploying!
ADMIN_USERNAME=aakassh
ADMIN_PASSWORD=YourStrongPassword123!
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars

# ── EMAIL (Gmail) ────────────────────────────────────
# Use an App Password (not your main password):
# Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=akashdev0@gmail.com
SMTP_PASS=your_gmail_app_password_here
NOTIFY_EMAIL=akashdev0@gmail.com

# ── TWILIO (WhatsApp / SMS) ──────────────────────────
# Sign up at twilio.com, get a free number
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1415XXXXXXX       # Your Twilio number (SMS)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886  # Twilio WhatsApp sandbox number
NOTIFY_PHONE=+919999999999            # Your personal phone (with country code)

# ── CORS ─────────────────────────────────────────────
# The domain where your frontend is hosted
FRONTEND_ORIGIN=https://aakassh.creates.com
